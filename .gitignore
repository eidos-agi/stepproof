# StepProof runtime state (machine-specific, ephemeral).
# NOTE: .stepproof/ itself is TRACKED — the layout mirrors .visionlog/.
# Only these child paths are runtime noise.
.stepproof/sessions/
.stepproof/audit-buffer.jsonl
.stepproof/adapter-manifest.json
.stepproof/runs/
.stepproof/events.jsonl
.stepproof/active-run.json
.stepproof/runtime.url
.stepproof.pre-init-backup/

# Machine-specific MCP registration (hardcoded paths to user's venv).
# Each developer writes their own .mcp.json per docs/RUN_A_CEREMONY.md.
.mcp.json

# Claude Code per-project settings. Reinstall via `stepproof install` to regenerate.
.claude/
.scratch/

# Hone notebook for this repo — per-target state, not source of truth
.hone/
