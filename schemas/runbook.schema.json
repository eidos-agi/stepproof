{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stepproof.eidosagi.com/schemas/runbook.schema.json",
  "title": "RunbookTemplate",
  "description": "A verification-aware runbook template. Every step declares what done means and how it will be verified.",
  "type": "object",
  "required": ["template_id", "version", "name", "risk_level", "steps"],
  "properties": {
    "template_id": {
      "type": "string",
      "pattern": "^rb-[a-z0-9-]+$",
      "description": "Stable identifier, e.g. rb-add-connector-fleetio"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver version of this template"
    },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "allowed_environments": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "requires_human_signoff": {
      "type": "boolean",
      "default": false
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/StepTemplate" }
    }
  },
  "$defs": {
    "StepTemplate": {
      "type": "object",
      "required": [
        "step_id",
        "description",
        "required_evidence",
        "verification_method",
        "verification_tier"
      ],
      "properties": {
        "step_id": {
          "type": "string",
          "pattern": "^s[0-9]+[a-z0-9-]*$",
          "description": "Stable within the template, e.g. s1, s2a"
        },
        "description": { "type": "string" },
        "allowed_tools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tool names permitted while on this step"
        },
        "denied_tools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Explicit deny list; overrides allowed_tools"
        },
        "required_evidence": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Evidence keys the worker must submit on completion"
        },
        "verification_method": {
          "type": "string",
          "description": "Name of the verifier function or prompt template"
        },
        "verification_tier": {
          "type": "string",
          "enum": ["tier1", "tier2", "tier3"]
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 600
        },
        "on_fail": {
          "type": "string",
          "enum": ["block", "retry", "escalate_human"],
          "default": "block"
        },
        "on_fail_max_retries": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    }
  }
}
